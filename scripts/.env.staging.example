# =============================================================================
# ProdeAR — Configuracion para sync de PROD a DEV
# =============================================================================
# Copiar este archivo a scripts/.env.staging y completar con los valores reales.
#
# IMPORTANTE: Este archivo NUNCA se commitea (esta en .gitignore).
#             Contiene credenciales sensibles (passwords de DB).
# =============================================================================

# -----------------------------------------------------------------------------
# Token de Supabase (CLI)
# -----------------------------------------------------------------------------
# Lo encontras en: https://supabase.com/dashboard/account/tokens
# Podes reusar el que ya esta en .env.local (SUPABASE_ACCESS_TOKEN)
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# PRODUCCION (origen) — prodear-prod
# -----------------------------------------------------------------------------
# Dashboard: https://supabase.com/dashboard/project/cdwefeqlxktliumtaqdc
PROD_PROJECT_REF=cdwefeqlxktliumtaqdc
PROD_DB_PASSWORD=xxxxxxxx

# -----------------------------------------------------------------------------
# DESARROLLO (destino) — ProdeAR
# -----------------------------------------------------------------------------
# Dashboard: https://supabase.com/dashboard/project/ijscgcpdfwlkgucjrmna
DEV_PROJECT_REF=ijscgcpdfwlkgucjrmna
DEV_DB_PASSWORD=xxxxxxxx

# =============================================================================
# INSTRUCCIONES:
# 1. cp scripts/.env.staging.example scripts/.env.staging
# 2. Editar scripts/.env.staging con los passwords reales
# 3. NUNCA commitear scripts/.env.staging
# 4. Para correr el sync: ./scripts/sync-prod-to-dev.sh
# =============================================================================
